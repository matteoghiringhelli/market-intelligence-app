{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/app",
      "destination": "/api/app"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/app?path=:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/daily-history-update",
      "schedule": "30 23 * * 1-5"
    },
    {
      "path": "/api/jobs/detect-technical-patterns",
      "schedule": "45 23 * * 1-5"
    }
  ]
}